# SQLite database (Prisma) — file path is relative to the schema location
DATABASE_URL="file:./prisma/dev.db"

# App
APP_URL="http://localhost:3000"   # base URL used to build magic-link URLs

# JWT signing
JWT_SECRET=""                     # `openssl rand -base64 32`

# SMTP (Mailgun EU, STARTTLS on 587)
SMTP_HOST="smtp.eu.mailgun.org"
SMTP_PORT="587"
SMTP_SECURE="false"               # false = use STARTTLS (587); true = implicit TLS (465)
SMTP_USER="wardly@benritec.com"
SMTP_PASS=""                      # Mailgun SMTP password
SMTP_FROM='"Wardly" <wardly@benritec.com>'

# Cron
CRON_SECRET=""                    # bearer token protecting /api/cron/*
